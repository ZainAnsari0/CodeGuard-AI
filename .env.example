# CodeGuard AI - Environment Variables
# Copy this file to .env and fill in the values

# === Application ===
DEBUG=false
PROJECT_NAME=CodeGuard AI

# === Database ===
POSTGRES_DB=codeguard
POSTGRES_USER=codeguard_user
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql+asyncpg://codeguard_user:change_me_in_production@localhost:5432/codeguard

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === JWT Authentication ===
JWT_SECRET_KEY=change_me_to_a_secure_random_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_PRIVATE_KEY_PATH=./certs/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./certs/jwt_public.pem

# === AI / LLM Providers ===
OPENAI_API_KEY=
GROQ_API_KEY=
OLLAMA_URL=http://localhost:11434
DEFAULT_MODEL=llama3:8b

# === Security ===
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# === File Upload ===
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=.py,.js,.ts,.java,.go,.rs,.c,.cpp,.h,.hpp,.swift

# === CORS ===
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# === Frontend ===
VITE_API_URL=http://localhost:8000